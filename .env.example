# AI Strategy Hub — Environment Configuration
# Copy this file to .env and fill in your API keys.

# ── Required for AI Features ──────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Required for Research Agent ───────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here

# ── Authentication (Optional) ────────────────────────────────
# Set an API key to protect all /api/ endpoints.
# When set, clients must send X-API-Key header.
# Leave empty for open access (development mode).
API_AUTH_KEY=

# ── Rate Limiting (Optional) ─────────────────────────────────
# RATE_LIMIT_DEFAULT=60/minute
# RATE_LIMIT_LLM=5/minute

# ── Logging (Optional) ───────────────────────────────────────
# LOG_LEVEL=INFO
